---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="CloudVerse OS Admin Dashboard" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Admin CloudVerse</title>
    <ClientRouter />
  </head>
  <body class="text-text-main font-sans antialiased min-h-screen selection:bg-primary/30">
    <slot />
  </body>
</html>
