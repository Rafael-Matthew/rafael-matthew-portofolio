---
import MainLayout from '../../layouts/MainLayout.astro';
import { supabase } from '../../lib/supabaseClient';
import { Calendar, Briefcase, Github, ExternalLink, ArrowLeft } from 'lucide-react';

const { slug } = Astro.params;

// In server mode, this fetches dynamically
const { data: project, error } = await supabase
  .from('projects')
  .select('*, project_images(image_url, sort_order)')
  .eq('slug', slug)
  .neq('status', 'draft')
  .single();

if (error || !project) {
  return Astro.redirect('/404');
}

const images = project.project_images?.sort((a, b) => a.sort_order - b.sort_order) || [];
---

<MainLayout title={`${project.title} | Projects`}>
  <article class="py-20">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <a href="/projects" class="inline-flex items-center space-x-2 text-text-muted hover:text-primary transition-colors mb-8">
        <ArrowLeft size={20} />
        <span>Back to Projects</span>
      </a>

      <div class="mb-10 text-center">
        <div class="inline-block px-3 py-1 bg-primary/10 rounded-full text-xs font-semibold text-primary mb-4">
          {project.category}
        </div>
        <h1 class="text-4xl md:text-5xl font-bold mb-6 text-text-main">{project.title}</h1>
        
        <div class="flex flex-wrap items-center justify-center gap-6 text-text-muted text-sm">
          <div class="flex items-center space-x-2">
            <Briefcase size={16} class="text-secondary" />
            <span>{project.role}</span>
          </div>
          <div class="flex items-center space-x-2">
            <Calendar size={16} class="text-accent" />
            <span>{project.period}</span>
          </div>
        </div>
      </div>

      <!-- Main Image -->
      <div class="rounded-3xl overflow-hidden bg-white shadow-sm border border-slate-100 mb-12 aspect-video relative">
        {project.image_url ? (
          <img src={project.image_url} alt={project.title} class="w-full h-full object-cover" />
        ) : (
          <div class="absolute inset-0 flex items-center justify-center">
            <Briefcase size={64} class="text-slate-200" />
          </div>
        )}
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <!-- Content -->
        <div class="md:col-span-2 space-y-8">
          <section>
            <h2 class="text-2xl font-bold mb-4 text-text-main">Overview</h2>
            <div class="text-text-muted leading-relaxed whitespace-pre-line">
              {project.description}
            </div>
          </section>

          {project.features && project.features.length > 0 && (
            <section>
              <h2 class="text-2xl font-bold mb-4 text-text-main">Key Features</h2>
              <ul class="space-y-2">
                {project.features.map((feature: string) => (
                  <li class="flex items-start">
                    <span class="text-primary mr-2 mt-1">•</span>
                    <span class="text-text-muted">{feature}</span>
                  </li>
                ))}
              </ul>
            </section>
          )}

          {/* Gallery */}
          {images.length > 0 && (
            <section>
              <h2 class="text-2xl font-bold mb-4 text-text-main">Gallery</h2>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {images.map((img: any) => (
                  <div class="rounded-xl overflow-hidden bg-white border border-slate-100 shadow-sm aspect-video">
                    <img src={img.image_url} alt={`${project.title} gallery image`} class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" />
                  </div>
                ))}
              </div>
            </section>
          )}
        </div>

        <!-- Sidebar -->
        <div class="space-y-8">
          <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
            <h3 class="text-lg font-bold mb-4 text-text-main">Tech Stack</h3>
            <div class="flex flex-wrap gap-2">
              {project.tech_stack && project.tech_stack.map((tech: string) => (
                <span class="px-3 py-1 bg-slate-50 rounded-md text-sm font-medium text-slate-700 border border-slate-200">
                  {tech}
                </span>
              ))}
            </div>
          </div>

          {(project.github_url || project.live_demo_url) && (
            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
              <h3 class="text-lg font-bold mb-4 text-text-main">Links</h3>
              <div class="space-y-3">
                {project.github_url && (
                  <a href={project.github_url} target="_blank" rel="noopener noreferrer" class="flex items-center space-x-3 text-text-muted hover:text-text-main transition-colors p-2 hover:bg-slate-50 rounded-lg">
                    <Github size={20} />
                    <span>Source Code</span>
                  </a>
                )}
                {project.live_demo_url && (
                  <a href={project.live_demo_url} target="_blank" rel="noopener noreferrer" class="flex items-center space-x-3 text-text-muted hover:text-primary transition-colors p-2 hover:bg-slate-50 rounded-lg">
                    <ExternalLink size={20} />
                    <span>Live Demo</span>
                  </a>
                )}
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </article>
</MainLayout>
