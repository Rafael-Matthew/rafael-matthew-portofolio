---
import MainLayout from '../layouts/MainLayout.astro';
import ExperienceTimeline from '../components/experience/ExperienceTimeline';
import { supabase } from '../lib/supabaseClient';

const { data: experiences, error } = await supabase
  .from('experiences')
  .select('*')
  .order('sort_order', { ascending: true });

if (error) {
  console.error("Error fetching experiences:", error);
}

const initialExperiences = experiences || [];
---

<MainLayout title="Experience" description="View the professional and organizational experience of Rafael Matthew Satrio.">
  <section class="py-20">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          My <span class="text-gradient">Experience</span>
        </h1>
        <div class="w-24 h-1 bg-primary mx-auto rounded-full mb-6"></div>
        <p class="text-text-muted max-w-2xl mx-auto text-lg">
          A journey through my professional roles, college projects, and organizational involvement.
        </p>
      </div>

      <ExperienceTimeline client:load initialExperiences={initialExperiences} />
    </div>
  </section>
</MainLayout>
