---
import MainLayout from '../../layouts/MainLayout.astro';
import ArticleCard from '../../components/blog/ArticleCard';
import { supabase } from '../../lib/supabaseClient';

const { data: articles, error } = await supabase
  .from('articles')
  .select('*')
  .eq('status', 'published')
  .order('created_at', { ascending: false });

if (error) {
  console.error("Error fetching articles:", error);
}

const publishedArticles = articles || [];
---

<MainLayout title="Blog" description="Read articles about web development, React, database, cloud technology, and software testing by Rafael Matthew Satrio.">
  <section class="py-20">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          My <span class="text-gradient">Blog</span>
        </h1>
        <div class="w-24 h-1 bg-primary mx-auto rounded-full mb-6"></div>
        <p class="text-text-muted max-w-2xl mx-auto text-lg">
          Thoughts, technical notes, and tutorials on web development and cloud engineering.
        </p>
      </div>

      {publishedArticles.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {publishedArticles.map((article, index) => (
            <ArticleCard client:load article={article} index={index} />
          ))}
        </div>
      ) : (
        <div class="text-center py-20">
          <p class="text-text-muted text-lg">Coming soon! I'm currently writing some interesting articles.</p>
        </div>
      )}
    </div>
  </section>
</MainLayout>
