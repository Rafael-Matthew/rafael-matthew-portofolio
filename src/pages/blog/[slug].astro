---
import MainLayout from '../../layouts/MainLayout.astro';
import { supabase } from '../../lib/supabaseClient';
import { Calendar, ArrowLeft } from 'lucide-react';

const { slug } = Astro.params;

const { data: article, error } = await supabase
  .from('articles')
  .select('*')
  .eq('slug', slug)
  .eq('status', 'published')
  .single();

if (error || !article) {
  return Astro.redirect('/404');
}

const date = new Date(article.created_at).toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric'
});
---

<MainLayout title={`${article.title} | Blog`} description={article.excerpt || undefined} image={article.cover_image_url || undefined}>
  <article class="py-20">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">
      <a href="/blog" class="inline-flex items-center space-x-2 text-text-muted hover:text-primary transition-colors mb-10">
        <ArrowLeft size={20} />
        <span>Back to Blog</span>
      </a>

      <div class="mb-10 text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-6 text-text-main">{article.title}</h1>
        
        <div class="flex flex-wrap items-center justify-center gap-6 text-text-muted text-sm">
          <div class="flex items-center space-x-2">
            <Calendar size={16} class="text-primary" />
            <time datetime={article.created_at}>{date}</time>
          </div>
        </div>
      </div>

      <!-- Main Image -->
      <div class="rounded-3xl overflow-hidden bg-white shadow-sm border border-slate-100 mb-12 aspect-video relative">
        {article.cover_image_url ? (
          <img src={article.cover_image_url} alt={article.title} class="w-full h-full object-cover" />
        ) : (
          <div class="absolute inset-0 flex items-center justify-center bg-slate-50">
            <span class="text-slate-300">No cover image</span>
          </div>
        )}
      </div>

      <!-- Content -->
      <div class="prose prose-lg prose-slate max-w-none prose-headings:text-text-main prose-a:text-primary hover:prose-a:text-primary-dark prose-strong:text-text-main prose-img:rounded-xl">
        {article.excerpt && (
          <p class="text-xl text-text-muted leading-relaxed font-medium italic mb-8 border-l-4 border-primary pl-6">
            {article.excerpt}
          </p>
        )}
        
        <div class="text-text-main leading-relaxed whitespace-pre-line">
          {article.content}
        </div>
      </div>
    </div>
  </article>
</MainLayout>

<style is:global>
  .prose h1, .prose h2, .prose h3 {
    color: var(--color-text-main);
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  .prose p {
    color: var(--color-text-muted);
    line-height: 1.625;
    margin-bottom: 1rem;
  }
  .prose a {
    color: var(--color-primary);
    text-decoration: underline;
    transition: color 0.2s;
  }
  .prose a:hover {
    color: var(--color-accent);
  }
  .prose ul {
    list-style-type: disc;
    padding-left: 1.5rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }
</style>
