---
import MainLayout from '../layouts/MainLayout.astro';
import EducationSection from '../components/education/EducationSection';
import { supabase } from '../lib/supabaseClient';

const { data: education, error } = await supabase
  .from('education')
  .select('*')
  .order('sort_order', { ascending: true });

if (error) {
  console.error("Error fetching education:", error);
}

const educationData = education || [];
---

<MainLayout title="Education" description="Educational background of Rafael Matthew Satrio, an Informatics Engineering student at ISTTS.">
  <section class="py-20">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <div class="text-center mb-16 relative z-10">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          My Education
        </h1>
        <div class="w-24 h-1 bg-primary mx-auto rounded-full mb-6"></div>
        <p class="text-text-muted max-w-2xl mx-auto text-lg">
          My academic background and achievements that shaped my knowledge and skills in computer science.
        </p>
      </div>

      <EducationSection client:load educationData={educationData} />
    </div>
  </section>
</MainLayout>
