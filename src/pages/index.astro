---
import Layout from '../layouts/Layout.astro';
import MissionNav from '@/components/layout/MissionNav';
import HeroCloudVerse from '@/components/sections/HeroCloudVerse';
import IdentityCore from '@/components/sections/IdentityCore';
import TechArsenal from '@/components/sections/TechArsenal';
import DeploymentZone from '@/components/sections/DeploymentZone';
import CloudIntelligenceEngine from '@/components/sections/CloudIntelligenceEngine';
import TimelinePipeline from '@/components/sections/TimelinePipeline';

import StartHandshake from '@/components/sections/StartHandshake';
import { supabase } from '@/lib/supabaseClient';

const { data: dbProjects, error } = await supabase.from('projects').select('*').order('created_at', { ascending: false });

if (error) {
  console.error("Supabase fetch error in index.astro:", error);
}

const fetchedProjects = dbProjects?.map((p: any) => ({
  id: p.slug,
  name: p.title,
  status: p.status,
  type: p.category,
  techStack: p.tech_stack || [],
  impact: p.impact || '',
  problem: p.problem || '',
  solution: p.solution || '',
  role: p.role,
  period: p.period || '2024',
  keyFeatures: p.features || [],
  demoUrl: p.live_demo_url || '#',
  githubUrl: p.github_url || '#',
  focus: p.focus || ['Developer'],
})) || [];
---

<Layout>
  <MissionNav client:load />
  
  <main class="relative w-full flex flex-col">
    <HeroCloudVerse client:load />
    <IdentityCore client:load />
    <TechArsenal client:load />
    <DeploymentZone client:load projects={fetchedProjects} />
    <CloudIntelligenceEngine client:load projects={fetchedProjects} />
    <TimelinePipeline client:load projects={fetchedProjects} />
    


    <StartHandshake client:load />
  </main>
  
  <footer class="py-8 text-center text-sm text-text-muted border-t border-slate-200 bg-white">
    <p>CloudVerse OS © {new Date().getFullYear()} by Rafael Matthew Satrio. All systems nominal.</p>
  </footer>
</Layout>
