---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-slate-200 bg-surface/50 mt-20">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col md:flex-row justify-between items-center">
      <div class="mb-4 md:mb-0 text-center md:text-left">
        <a href="/" class="text-2xl font-bold text-white tracking-tighter">
          Rafael<span class="text-primary">.</span>
        </a>
        <p class="text-text-muted mt-2 text-sm max-w-sm">
          Informatics Engineering Student & Full-Stack Developer passionate about building practical digital systems.
        </p>
      </div>

      <div class="flex space-x-6">
        <a href="https://linkedin.com/in/r-matthew" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-white transition-colors">
          <span class="sr-only">LinkedIn</span>
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
          </svg>
        </a>
        <a href="mailto:rafaelmatthew2305@gmail.com" class="text-text-muted hover:text-white transition-colors">
          <span class="sr-only">Email</span>
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
